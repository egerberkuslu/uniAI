# Core database configuration (localhost for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rbac_rag_db
DB_USER=postgres
DB_PASSWORD=postgres

# LLM selection
USE_CLAUDE_API=false
CLAUDE_MODEL=claude-sonnet-4-20250514
LOCAL_MODEL_NAME=deepseek-r1:14b
OLLAMA_HOST=http://localhost:11434
LLM_MAX_TOKENS=512
USE_LLM_ROUTER=true
LLM_ROUTER_MAX_TOKENS=700

# Embedding + RAG tuning
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=200
CHUNK_OVERLAP=50
RAG_TOP_K=3
SIMILARITY_THRESHOLD=0.3

# MCP server binding
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_TRANSPORT=stdio

# Optional: provide Anthropic key when USE_CLAUDE_API=true
# ANTHROPIC_API_KEY=sk-ant-...
